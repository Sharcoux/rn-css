{
  "name": "rn-css",
  "version": "2.0.0",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./*": {
      "import": "./dist/*/index.js",
      "require": "./dist/*/index.js"
    }
  },
  "typesVersions": {
    "*": {
      ".": [
        "dist/index.d.ts"
      ],
      "./*": [
        "dist/*/index.d.ts"
      ]
    }
  },
  "scripts": {
    "test": "jest",
    "prepare": "rm -rf dist && tsc && webpack",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "lint": "eslint --fix .",
    "build": "webpack",
    "release": "npm run prepare && release-it",
    "web": "webpack serve --open --mode development"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-native": ">=0.82.0",
    "react-native-web": ">=0.21.0",
    "react-dom": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "react-native-web": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/core": "^7.16.5",
    "@babel/preset-typescript": "^7.26.0",
    "@babel/runtime": "^7.16.5",
    "@react-native-community/eslint-config": "^3.0.1",
    "@types/jest": "^29.5.12",
    "@types/react": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^5.7.0",
    "@typescript-eslint/parser": "^5.7.0",
    "babel-jest": "^29.7.0",
    "babel-loader": "^8.2.3",
    "dotenv": "^10.0.0",
    "eslint": "^7.32.0",
    "eslint-config-standard": "^16.0.3",
    "eslint-plugin-import": "^2.25.3",
    "eslint-plugin-jest": "^25.3.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^5.2.0",
    "eslint-plugin-react": "^7.27.1",
    "eslint-plugin-react-hooks": "^4.4.0",
    "eslint-plugin-standard": "^5.0.0",
    "html-loader": "^3.0.1",
    "html-webpack-plugin": "^5.5.0",
    "husky": "^7.0.4",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^12.1.2",
    "metro-react-native-babel-preset": "^0.77.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "^0.82.0",
    "react-native-typescript-transformer": "^1.2.13",
    "react-native-web": "^0.21.1",
    "react-test-renderer": "19.2.0",
    "release-it": "^15.6.0",
    "ts-jest": "^29.1.2",
    "ts-loader": "^9.2.6",
    "typescript": "^4.5.4",
    "webpack": "^5.72.0",
    "webpack-cli": "^4.9.2",
    "webpack-dev-server": "^4.8.1"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.(js|jsx|ts|tsx)$": "babel-jest"
    },
    "setupFilesAfterEnv": [
      "<rootDir>/tests/jest/setup.js"
    ],
    "moduleNameMapper": {
      "^react-native$": "<rootDir>/tests/jest/react-native-mock.js",
      "^react-native/jest/mock$": "<rootDir>/tests/jest/rn-mock.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "husky": {
    "hooks": {
      "pre-commit": "tsc --noEmit && lint-staged"
    }
  },
  "lint-staged": {
    "*.[tj]s?(x)": [
      "eslint . --fix",
      "git add"
    ]
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "homepage": "https://github.com/Sharcoux/rn-css",
  "author": {
    "name": "François Billioud",
    "email": "f.billioud@gmail.com"
  },
  "bugs": {
    "url": "https://github.com/Sharcoux/rn-css/issues",
    "email": "f.billioud@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:Sharcoux/rn-css.git"
  },
  "sideEffects": false,
  "license": "ISC"
}
